# change this to a long random string in production
SECRET_KEY=dev-secret-change-me

# leave blank to just print OTPs to the console (good for local testing)
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@swimscore.local

# default admin credentials on first run
ADMIN_EMAIL=admin@swimscore.local
ADMIN_PASSWORD=Admin1234!

# optional - defaults to sqlite:///swim.db in the instance folder
# DATABASE_URL=sqlite:///swim.db
